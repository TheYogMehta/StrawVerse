{
  "appId": "app.strawverse.android",
  "appName": "StrawVerse",
  "webDir": "www",
  "server": {
    "androidScheme": "http",
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CapacitorNodeJS": {
      "nodeDir": "nodejs"
    },
    "CapacitorHttp": {
      "enabled": false
    },
    "CapacitorCookies": {
      "enabled": false
    }
  }
}
