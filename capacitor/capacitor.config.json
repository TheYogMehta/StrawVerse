{
  "appId": "app.strawverse.android",
  "appName": "StrawVerse",
  "webDir": "www",
  "server": {
    "androidScheme": "http",
    "allowNavigation": [
      "localhost",
      "127.0.0.1",
      "http://localhost:3459",
      "http://127.0.0.1:3459"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CapacitorNodeJS": {
      "nodeDir": "nodejs"
    },
    "CapacitorHttp": {
      "enabled": false
    },
    "CapacitorCookies": {
      "enabled": false
    }
  }
}
