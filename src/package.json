{
  "name": "strawverse",
  "version": "6.0.1",
  "description": "Download anime in batches & its fast :3",
  "main": "gui.js",
  "scripts": {
    "start": "electron . --trace-warnings",
    "build": "npm run build --prefix gui",
    "package": "electron-builder --win --linux",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheYogMehta/StrawVerse.git"
  },
  "build": {
    "appId": "com.animebatchdownloader.gui",
    "protocols": [
      {
        "name": "strawverse-protocols",
        "schemes": [
          "strawverse"
        ]
      }
    ],
    "files": [
      "**/*",
      "!gui/node_modules/**/*",
      "!gui/public/**/*",
      "!gui/src/**/*",
      "!gui/.gitignore",
      "!gui/eslint.config.js",
      "!gui/package.json",
      "!gui/package-lock.json",
      "!gui/vite.config.js"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "StrawVerse.Setup.${version}.exe",
      "icon": "assets/luffy.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "TheYogMehta",
      "repo": "StrawVerse",
      "private": false
    },
    "nsis": {
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ],
      "icon": "assets/luffy.png",
      "desktop": {
        "MimeType": "x-scheme-handler/strawverse;"
      }
    },
    "icon": "assets/luffy.png",
    "compression": "normal",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "assets/**/*"
    ]
  },
  "keywords": [
    "anime",
    "manga",
    "mangadownloader",
    "animedownloader",
    "animebatchdownloader",
    "StrawVerse"
  ],
  "author": {
    "name": "TheYogMehta",
    "email": "mehtayog5@gmail.com",
    "url": "https://github.com/TheYogMehta"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^1.17.0",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "discord-rpc": "^4.0.1",
    "ejs": "^6.0.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "fs-extra": "^11.3.5",
    "got": "^15.0.5",
    "hls-parser": "^0.16.1",
    "image-pixels": "^2.2.2",
    "iso-639-1": "^3.1.5",
    "jszip": "^3.10.1",
    "mpd-parser": "^1.3.1",
    "node-cache": "^5.1.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
